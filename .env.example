OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_VECTOR_STORE_ID=
DATABASE_URL=
PORT=8787
HOST=127.0.0.1
CLIENT_ORIGIN=http://127.0.0.1:5173
BRAND_NAME="Aster & Ridge"
VITE_API_BASE=

# Google Analytics 4 browser collection and Measurement Protocol diagnostics.
# The Vite client exposes only the public Measurement ID and sends shopper events with gtag.js.
# Create GA4 API secret under Admin > Data streams > Measurement Protocol API secrets.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# Optional frontend override for static builds. Do not create VITE_ variables for API secrets.
VITE_GA4_MEASUREMENT_ID=
VITE_GA4_DEBUG_MODE=true
# Optional. Use region1.google-analytics.com if you need EU collection.
GA4_COLLECT_HOST=https://www.google-analytics.com
# Optional. Keep true for demos so events appear in GA4 DebugView.
GA4_DEBUG_MODE=true

# Optional GA4 Data API reporting for Analytics Agent dashboard reads.
# Give this service account Viewer access to the GA4 property.
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=
# Alternative to GA4_CLIENT_EMAIL/GA4_PRIVATE_KEY:
GA4_SERVICE_ACCOUNT_JSON=
